# =============================================================================
# zot-research-engine — Environment Variables
# =============================================================================
# Copy this file to ".env" and fill in your own values.
#   cp .env.example .env
#
# NEVER commit your real ".env" file — it is already listed in .gitignore.
# In production (GitHub Actions), these are provided as repository Secrets
# instead of a .env file.
# =============================================================================

# Google Gemini API key.
# Get one for free at Google AI Studio: https://aistudio.google.com/
#   -> Click "Get API key" -> "Create API key".
# Only used to polish the shortlist of high-scoring papers; relevance scoring
# itself is free and offline. Set gemini.enrich: false in config.yaml to skip it.
GEMINI_API_KEY=

# Zotero API key (private key with write access to your library).
# Create one at: https://www.zotero.org/settings/keys/new
#   -> Check "Allow library access" and "Allow write access".
ZOTERO_API_KEY=

# Your numeric Zotero user ID (NOT your username).
# Find it at: https://www.zotero.org/settings/keys
#   -> Shown as "Your userID for use in API calls is XXXXXXX".
ZOTERO_USER_ID=

# Library type: "user" for a personal library, or "group" for a group library.
# Almost always "user".
ZOTERO_LIBRARY_TYPE=user

# Your email address. Sent to OpenAlex to join their faster "polite pool".
# https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_EMAIL=
